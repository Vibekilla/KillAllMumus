NODE_ENV=production
# Live: 3000  |  Dev (/var/www/dev → dev.killallmumus.com): 3001
PORT=3000
HOSTNAME=127.0.0.1
# Live: https://killallmumus.com  |  Dev: https://dev.killallmumus.com
PUBLIC_ORIGIN=https://killallmumus.com
# Godot default client — keep 0 until Phase 7 dual sign-off
USE_GODOT=0

DATABASE_URL=postgresql://killallmumus:CHANGE_ME@127.0.0.1:5433/killallmumus
PGHOST=127.0.0.1
PGPORT=5433
PGUSER=killallmumus
PGPASSWORD=CHANGE_ME
PGDATABASE=killallmumus

# Bobina.moe OAuth (Council → System → OAuth Apps)
# Live redirect:  https://killallmumus.com/auth/bobina/callback
# Dev redirect:   https://dev.killallmumus.com/auth/bobina/callback  (add in Bobina app if using OAuth on dev)
# Scopes: openid profile social
BOBINA_CLIENT_ID=
BOBINA_CLIENT_SECRET=
BOBINA_REDIRECT_URI=https://killallmumus.com/auth/bobina/callback
BOBINA_ISSUER=https://bobina.moe
