; Engine configuration file.
; Godot 4.3 — Bobina: Kill All Mumus (modular port)
config_version=5

[application]

config/name="Kill All Mumus"
config/description="Bobina: Kill All Mumus!! — modular Godot port"
run/main_scene="res://scenes/main/Main.tscn"
run/max_fps=60
config/features=PackedStringArray("4.3", "GL Compatibility")
config/icon="res://assets/textures/clear-0.png"

[autoload]

Config="*res://autoload/Config.gd"
FontBank="*res://autoload/FontBank.gd"
GameState="*res://autoload/GameState.gd"
DataRegistry="*res://autoload/DataRegistry.gd"
ProgressStore="*res://autoload/ProgressStore.gd"
ApiClient="*res://autoload/ApiClient.gd"
AudioBus="*res://autoload/AudioBus.gd"
MusicBridge="*res://scripts/audio/MusicBridge.gd"
SimClock="*res://scripts/html_parity/SimClock.gd"
AssetBank="*res://scripts/html_parity/AssetBank.gd"
P2Meta="*res://scripts/ui/menu/P2Meta.gd"
CombatHelpers="*res://scripts/combat/CombatHelpers.gd"
ItemSystem="*res://scripts/systems/ItemSystem.gd"
StageFlow="*res://scripts/stages/StageFlow.gd"
JoyPad="*res://scripts/input/JoyPad.gd"
InputRouter="*res://scripts/input/InputRouter.gd"

[display]

window/size/viewport_width=960
window/size/viewport_height=540
window/size/mode=0
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"
window/handheld/orientation=0
window/vsync/vsync_mode=1

