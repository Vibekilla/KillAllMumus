extends RefCounted
## 1:1 port of HTML drawMeleeFx

var ctx
var tick: int = 0
var selected_outfit: String = "og"
var EAR_HIDE := {
	"neko": true, "monke": true, "kigurumi": true, "cheese": true, "cabal": true,
	"badger": true, "viking": true, "samurai": true, "bullbina": true, "jester": true,
	"succubus": true, "squirrely": true, "banana": true
}
var _armCol = "#5f3823"
var _armW: float = 3.8
var _handCols = null
var _hold = null
var _armSw: float = 0.0
var _sBob: float = 0.0

func setup(c) -> void:
	ctx = c

func set_tick(t: int) -> void:
	tick = t

func set_outfit(o: String) -> void:
	selected_outfit = o

func p_orb(x, y, glow, c1, c2) -> void:
	ctx.save()
	ctx.translate(float(x), float(y))
	ctx.global_alpha(0.55)
	ctx.fill_style(str(glow))
	ctx.begin_path()
	ctx.arc(0, 0, 5.5, 0, TAU)
	ctx.fill()
	ctx.global_alpha(1.0)
	ctx.fill_style(str(c1))
	ctx.begin_path()
	ctx.arc(0, 0, 3.2, 0, TAU)
	ctx.fill()
	ctx.fill_style(str(c2))
	ctx.begin_path()
	ctx.arc(-0.8, -0.8, 1.2, 0, TAU)
	ctx.fill()
	ctx.restore()

func draw_circle_helper(x, y, r, col) -> void:
	ctx.fill_style(col)
	ctx.begin_path()
	ctx.arc(float(x), float(y), float(r), 0, TAU)
	ctx.fill()

func drawMeleeFx() -> void:
	for f in meleeFx:
		var pr = f.t / f.life
		if f.bolt:
			var al = 1 - pr
			ctx.save()
			ctx.global_composite_operation("lighter")
			ctx.stroke_style(f.col)
			ctx.shadow_color(f.col)
			ctx.shadow_blur(8)
			ctx.line_cap("round")
			ctx.line_join("round")
			ctx.global_alpha(al)
			ctx.line_width(2.4)
			for i in range(int(1), int(f.pts.size())):
				var a = f.pts[i - 1]
				var b = f.pts[i]
				ctx.begin_path()
				ctx.move_to(a.x, a.y)
				for s in range(int(1), int(4) + 1):
					var tt = s / 4
					# TODO_PORT: ctx.lineTo(
					# TODO_PORT: a.x + (b.x - a.x) * tt + (Math.random() - 0.5) * 9, a.y + (b.y - a.y) * tt + (Math.random() - 0.5) * 9, )
				ctx.stroke()
			ctx.shadow_blur(0)
			ctx.stroke_style("#fff")
			ctx.line_width(1)
			for i in range(int(1), int(f.pts.size())):
				var a = f.pts[i - 1]
				var b = f.pts[i]
				ctx.begin_path()
				ctx.move_to(a.x, a.y)
				ctx.line_to(b.x, b.y)
				ctx.stroke()
			ctx.restore()
			ctx.global_alpha(1)
			continue
		if f.ring:
			var r = f.r0 + (f.r1 - f.r0) * pr
			var al = 1 - pr
			ctx.save()
			ctx.global_composite_operation("lighter")
			ctx.translate(f.x, f.y)
			ctx.line_width(5 * (1 - pr) + 1)
			if f.rainbow:
				var base = (tick * 4) % 360
				var segs = 24
				for s in range(int(0), int(segs)):
					var a0 = (s / segs) * 6.283
					var a1 = ((s + 1) / segs) * 6.283 + 0.02
					var hue = (base + (s / segs) * 360) % 360
					ctx.stroke_style("hsla(" + str(hue) + ",100%,64%," + str(al * 0.85) + ")")
					ctx.begin_path()
					ctx.arc(0, 0, r, a0, a1)
					ctx.stroke()
			else:
				ctx.stroke_style(f.col)
				ctx.shadow_color(f.col)
				ctx.shadow_blur(16)
				ctx.global_alpha(al * 0.75)
				ctx.begin_path()
				ctx.arc(0, 0, r, 0, 7)
				ctx.stroke()
				ctx.global_alpha(al)
				ctx.stroke_style("#fff")
				ctx.line_width(1.5)
				ctx.begin_path()
				ctx.arc(0, 0, r * 0.96, 0, 7)
				ctx.stroke()
			ctx.restore()
			ctx.global_alpha(1)
			continue
		var rad = f.reach * (0.55 + pr * 0.45)
		var a0 = f.dir - f.half
		var a1 = f.dir + f.half
		var al = 1 - pr
		ctx.save()
		ctx.global_composite_operation("lighter")
		ctx.translate(f.x, f.y)
		ctx.line_cap("round")
		ctx.line_join("round")
		ctx.global_alpha(al * 0.8)
		ctx.stroke_style(f.col)
		ctx.line_width(6 + f.charge * 9)
		ctx.shadow_color(f.col)
		ctx.shadow_blur(16)
		ctx.begin_path()
		ctx.arc(0, 0, rad, a0, a1)
		ctx.stroke()
		ctx.global_alpha(al)
		ctx.stroke_style("#fff")
		ctx.line_width(2.2)
		ctx.begin_path()
		ctx.arc(0, 0, rad * 0.98, a0, a1)
		ctx.stroke()
		var swing = a0 + minf(1, pr * 1.2) * (a1 - a0)
		ctx.rotate(swing)
		ctx.global_alpha(maxf(0.22, 1 - pr * 0.62))
		ctx.shadow_blur(10)
		drawMeleeWeapon(f.key, f.reach * 0.92, f.col, f.charge)
		ctx.restore()
		ctx.global_alpha(1)
	var p = player
	if p  and  !p.dead  and  p.meleeHeld  and  (p.get("meleeChg", 0) > 0.04):
		var m = MELEE[p.get("melee", 0] ) or  MELEE[0]
		var c = p.meleeChg
		var _mc = bodyCtr(p)
		ctx.save()
		ctx.global_composite_operation("lighter")
		ctx.translate(_mc.x, _mc.y)
		ctx.stroke_style(m.col)
		ctx.shadow_color(m.col)
		ctx.shadow_blur(10)
		ctx.line_cap("round")
		ctx.global_alpha(0.5 + 0.4 * c)
		ctx.line_width(2.6)
		ctx.begin_path()
		ctx.arc(0, 0, 15 + c * 7, -PI / 2, -PI / 2 + c * PI * 2)
		ctx.stroke()
		if c >= 1:
			ctx.global_alpha(0.5 + 0.4 * sin(tick * 0.5))
			ctx.line_width(2)
			ctx.begin_path()
			ctx.arc(0, 0, 24, 0, 7)
			ctx.stroke()
		ctx.restore()
		ctx.global_alpha(1)
