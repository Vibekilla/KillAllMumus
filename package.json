    "pg": "^8.22.0",
    "sharp": "^0.35.3"
  },
  "emblem_build": {
    "tables": [
      {
        "name": "bobina_scores",
        "schema": "CREATE TABLE IF NOT EXISTS bobina_scores (id INTEGER PRIMARY KEY AUTOINCREMENT, name TEXT, handle TEXT, score INTEGER, kills INTEGER, rank TEXT, mode TEXT, won INTEGER, outfit TEXT DEFAULT 'og', created_at TEXT DEFAULT (datetime('now')))"
      }
    ]
  },
  "description": "Bobina: Kill All Mumus — killallmumus.com",
