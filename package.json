    "port:gate:p2": "node tools/port/phase_gates/check_p2.mjs",
    "port:gate:p3": "node tools/port/phase_gates/check_p3.mjs",
    "port:gate:p5": "node tools/port/phase_gates/check_p5.mjs",
    "port:gate:p6": "node tools/port/phase_gates/check_p6.mjs",
    "port:gate:p7": "node tools/port/phase_gates/check_p7.mjs",
    "port:gate:p8": "node tools/port/phase_gates/check_p8.mjs",
    "port:gate:p9": "node tools/port/phase_gates/check_p9.mjs",
    "port:inventory": "node tools/port/inventory_public.mjs",
    "port:dual": "node tools/port/dual_playtest.mjs",
    "port:dual:full": "node tools/port/dual_playtest.mjs --full"
