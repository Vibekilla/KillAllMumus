{
  "name": "killallmumus",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "node server.js",
    "start:prod": "node server.js",
    "db:backup": "bash scripts/db-backup.sh",
    "db:pg-start": "bash scripts/pg-start.sh",
    "db:pg-stop": "bash scripts/pg-stop.sh",
    "services:install": "bash scripts/install-user-services.sh",
    "port:extract": "node tools/port/full_extract.mjs",
    "port:convert": "node tools/port/js_to_gd.mjs",
    "port:sync": "node tools/port/sync_exact_client.mjs",
    "port:verify": "node tools/port/verify_parity.mjs",
    "port:gates": "node tools/port/phase_gates/run_all.mjs",
    "port:gate:0": "node tools/port/phase_gates/check_phase0.mjs",
    "port:gate:1": "node tools/port/phase_gates/check_phase1.mjs",
    "port:gate:2": "node tools/port/phase_gates/check_phase2.mjs",
    "port:gate:3": "node tools/port/phase_gates/check_phase3.mjs",
    "port:gate:4": "node tools/port/phase_gates/check_phase4.mjs",
    "port:gate:5": "node tools/port/phase_gates/check_phase5.mjs",
    "port:gate:6": "node tools/port/phase_gates/check_phase6.mjs",
    "port:gate:7": "node tools/port/phase_gates/check_phase7.mjs",
    "port:gate:8": "node tools/port/phase_gates/check_phase8.mjs",
    "port:gate:p0": "node tools/port/phase_gates/check_phase0.mjs",
    "port:gate:p1": "node tools/port/phase_gates/check_phase1.mjs",
    "port:inventory": "node tools/port/inventory_public.mjs",
    "port:dual": "node tools/port/dual_playtest.mjs",
    "port:dual:full": "node tools/port/dual_playtest.mjs --full",
    "port:fps": "xvfb-run -a -s '-screen 0 960x540x24' ${GODOT:-$HOME/.local/godot/godot} --path godot --script res://scripts/tools/fps_probe.gd"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "express": "^4.22.2",
    "jose": "^6.2.4",
    "pg": "^8.22.0",
    "sharp": "^0.35.3"
  },
  "emblem_build": {
    "tables": [
      {
        "name": "bobina_scores",
        "schema": "CREATE TABLE IF NOT EXISTS bobina_scores (id INTEGER PRIMARY KEY AUTOINCREMENT, name TEXT, handle TEXT, score INTEGER, kills INTEGER, rank TEXT, mode TEXT, won INTEGER, outfit TEXT DEFAULT 'og', created_at TEXT DEFAULT (datetime('now')))"
      }
    ]
  },
  "description": "Bobina: Kill All Mumus — killallmumus.com",
  "engines": {
    "node": ">=20.9.0"
  },
  "devDependencies": {
    "playwright": "^1.61.1"
  }
}
